PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/dbname

# PINs für die drei Zugänge. PIN_ADMIN unbedingt setzen –
# nur der Admin-Zugang wird auch serverseitig geprüft!
PIN_ADMIN=
PIN_PLANER=
PIN_CLEANER=

# Optional: eigener Schlüssel zum Signieren der Admin-Login-Cookies
# (sonst wird PIN_ADMIN dafür verwendet)
SESSION_SECRET=

# Geheimer Token für den automatischen Excel-Import via Make.com
# Beispiel-Token (bitte durch einen eigenen ersetzen):
AUTO_IMPORT_TOKEN=bitte-hier-einen-eigenen-geheimen-token-eintragen
